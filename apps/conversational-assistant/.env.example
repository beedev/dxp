# ============================================
# LLM Configuration
# ============================================
OPENAI_API_KEY=sk-proj-your-key-here
LLM_PROVIDER=openai
LLM_MODEL=gpt-4.1
EMBEDDING_MODEL=text-embedding-3-small
PGVECTOR_EMBED_DIM=1536

# ============================================
# Database (PostgreSQL + pgvector + Apache AGE)
# ============================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agentic_commerce
POSTGRES_USER=agentic
POSTGRES_PASSWORD=agentic_dev_2026
DATABASE_URL=postgresql+asyncpg://agentic:agentic_dev_2026@localhost:5432/agentic_commerce

# ============================================
# Redis
# ============================================
REDIS_URL=redis://localhost:6379/0

# ============================================
# Langfuse Observability
# ============================================
LANGFUSE_ENABLED=true
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ============================================
# Application
# ============================================
API_HOST=0.0.0.0
API_PORT=8000
WEB_PORT=3000
ENV=development
DEBUG=true
