{
  "id": "ace-hardware-retail",
  "description": "Ace Hardware retail product catalog",
  "source": {
    "type": "json_file",
    "path": "/tmp/ace_products.json"
  },
  "entity": {
    "name": "product",
    "display_name": "Product",
    "display_name_plural": "Products",
    "primary_key_field": "sku",
    "group_field": "category",
    "group_label_field": "brand",
    "field_map": {
      "sku": "sku",
      "name": "name",
      "description": "description",
      "category": "category",
      "brand": "brand",
      "price": "price",
      "msrp": "msrp",
      "attributes": "specs",
      "rating": "rating",
      "review_count": "reviewCount",
      "image_url": "imageUrl"
    },
    "card_layout": {
      "headline": "name",
      "subtitle": "brand",
      "primary_metric": { "field": "price", "format": "currency", "label": "Price" },
      "secondary_metrics": [
        { "field": "rating", "format": "rating", "label": "Rating" },
        { "field": "review_count", "label": "Reviews" }
      ],
      "badge": "category"
    },
    "action": { "label": "Add to Cart", "type": "add_to_cart" }
  },
  "embeddings": {
    "provider": "openai",
    "model": "text-embedding-3-small",
    "dimensions": 1536,
    "template": "{name} by {brand}. Category: {category}. {description}"
  },
  "graph": {
    "enabled": true,
    "graph_name": "agentic_commerce",
    "relationships": {
      "made_by": true,
      "belongs_to": true,
      "similar_to": true
    }
  },
  "users_file": "ace-hardware",
  "coupons_file": "ace-hardware"
}
