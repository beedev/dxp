{
  "id": "insurance-claims-advisor",
  "description": "Insurance policies and plans catalog",
  "source": {
    "type": "json_file",
    "path": "/tmp/insurance_plans.json"
  },
  "entity": {
    "name": "insurance_plan",
    "display_name": "Insurance Plan",
    "display_name_plural": "Insurance Plans",
    "primary_key_field": "plan_id",
    "group_field": "coverage_type",
    "group_label_field": "provider",
    "field_map": {
      "plan_id": "planId",
      "name": "name",
      "provider": "provider",
      "coverage_type": "coverageType",
      "description": "description",
      "monthly_premium": "monthlyPremium",
      "deductible": "deductible",
      "coverage_limit": "coverageLimit",
      "rating": "rating",
      "network": "network",
      "key_benefits": "keyBenefits"
    },
    "card_layout": {
      "headline": "name",
      "subtitle": "provider",
      "primary_metric": { "field": "monthly_premium", "format": "currency", "label": "/month" },
      "secondary_metrics": [
        { "field": "deductible", "format": "currency", "label": "Deductible" },
        { "field": "coverage_type", "label": "Type" }
      ],
      "badge": "coverage_type"
    },
    "action": { "label": "Get Quote", "type": "get_quote" }
  },
  "embeddings": {
    "provider": "openai",
    "model": "text-embedding-3-small",
    "dimensions": 1536,
    "template": "{name} by {provider}. {coverage_type} insurance. {description}. Benefits: {key_benefits}"
  },
  "graph": {
    "enabled": false
  }
}
