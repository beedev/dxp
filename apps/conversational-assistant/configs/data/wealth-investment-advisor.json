{
  "id": "wealth-investment-advisor",
  "description": "Investment products — stocks, funds, ETFs, gold, forex",
  "source": {
    "type": "json_file",
    "path": "/tmp/wealth_investment_products.json"
  },
  "entity": {
    "name": "investment_product",
    "display_name": "Investment Product",
    "display_name_plural": "Investment Products",
    "primary_key_field": "symbol",
    "group_field": "sector",
    "group_label_field": "asset_class",
    "field_map": {
      "symbol": "symbol",
      "name": "name",
      "asset_class": "assetClass",
      "sector": "sector",
      "risk_level": "riskLevel",
      "description": "description",
      "return_1y": "return1Y",
      "return_3y": "return3Y",
      "expense_ratio": "expenseRatio",
      "min_investment": "minInvestment",
      "price": "price",
      "currency": "currency",
      "currency_symbol": "currencySymbol",
      "exchange": "exchange"
    },
    "card_layout": {
      "headline": "name",
      "subtitle": "asset_class",
      "primary_metric": { "field": "price", "format": "currency", "label": "Price" },
      "secondary_metrics": [
        { "field": "return_1y", "format": "percent", "label": "1Y Return" },
        { "field": "risk_level", "label": "Risk" }
      ],
      "badge": "sector"
    },
    "action": {
      "label": "Trade",
      "type": "place_order",
      "form": [
        { "field": "side", "type": "toggle", "options": ["buy", "sell"], "default": "buy" },
        { "field": "type", "type": "select", "options": ["market", "limit", "stop"], "default": "market" },
        { "field": "qty", "type": "number", "label": "Qty", "default": 100 },
        { "field": "price", "type": "number", "label": "Limit Price", "show_when": "type != market" },
        { "field": "validity", "type": "select", "options": ["DAY", "GTC"], "default": "GTC" }
      ]
    }
  },
  "embeddings": {
    "provider": "openai",
    "model": "text-embedding-3-small",
    "dimensions": 1536,
    "template": "{name} ({symbol}). Asset class: {asset_class}. Sector: {sector}. Risk: {risk_level}. {description}"
  },
  "graph": {
    "enabled": false
  }
}
