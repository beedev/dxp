# DXP Platform — Environment Configuration
# Copy to .env and adjust values.

# --- PostgreSQL ---
POSTGRES_USER=dxp
POSTGRES_PASSWORD=dxp_local_pass
POSTGRES_DB=dxp

# --- Redis ---
REDIS_PASSWORD=dxp_redis_pass

# --- Keycloak ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=dxp

# --- BFF ---
BFF_PORT=3000
CMS_ADAPTER=strapi
STORAGE_PROVIDER=s3

# --- Adapter Config (per engagement) ---
STRAPI_URL=http://localhost:1337
STRAPI_API_TOKEN=
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=dxp-documents
S3_ACCESS_KEY=
S3_SECRET_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SENDGRID_API_KEY=

# Wealth Portal — Market Data & Trading
MARKET_DATA_ADAPTER=mock
ALPHA_VANTAGE_KEY=demo
FX_ADAPTER=mock
NEWS_ADAPTER=mock
NEWSAPI_KEY=
BRAVE_SEARCH_KEY=
MACRO_ADAPTER=mock
PORTFOLIO_ADAPTER=mock
WATCHLIST_ADAPTER=mock
TRADING_ADAPTER=paper
BROKER_PROVIDER=tiger
TIGER_BROKER_ID=
TIGER_PRIVATE_KEY=
TIGER_ACCOUNT=
IBKR_ACCOUNT=
IBKR_CLIENT_ID=
IBKR_CLIENT_SECRET=
