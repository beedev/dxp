# DXP Platform — Environment Configuration
# Copy to .env and adjust values.

# --- PostgreSQL ---
POSTGRES_USER=dxp
POSTGRES_PASSWORD=dxp_local_pass
POSTGRES_DB=dxp

# --- Redis ---
REDIS_PASSWORD=dxp_redis_pass

# --- Keycloak ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=dxp

# --- BFF ---
BFF_PORT=4201
CMS_ADAPTER=strapi
STORAGE_PROVIDER=s3

# --- Adapter Config (per engagement) ---
STRAPI_URL=http://localhost:1337
STRAPI_API_TOKEN=
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=dxp-documents
S3_ACCESS_KEY=
S3_SECRET_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SENDGRID_API_KEY=

# --- Wealth Portal — Market Data & Trading ---
MARKET_DATA_ADAPTER=yahoo-finance
ALPHA_VANTAGE_KEY=
FX_ADAPTER=exchangerate-api
NEWS_ADAPTER=google-news
BRAVE_SEARCH_KEY=
MACRO_ADAPTER=worldbank
PORTFOLIO_ADAPTER=mock
WATCHLIST_ADAPTER=mock
TRADING_ADAPTER=paper
BROKER_PROVIDER=tiger
TIGER_BROKER_ID=
TIGER_PRIVATE_KEY=
TIGER_ACCOUNT=
IBKR_ACCOUNT=
IBKR_CLIENT_ID=
IBKR_CLIENT_SECRET=

# --- Dev Auth Bypass (local development only — never set in production) ---
DEV_AUTH_BYPASS=true
DEV_MEMBER_ID=

# --- Conversational AI Assistant ---
AGENTIC_ADAPTER=langgraph
AGENTIC_BACKEND_URL=http://localhost:8002
AGENTIC_CONFIG_ID=ace-hardware
OPENAI_API_KEY=
LLM_MODEL=gpt-4.1
EMBEDDING_MODEL=text-embedding-3-small
BFF_BASE_URL=http://localhost:4201/api
LANGFUSE_ENABLED=false
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
